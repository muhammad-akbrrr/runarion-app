{
  "description": "Full configuration for comprehensive testing",
  "processing": {
    "provider": "openai",
    "model": "gpt-4o",
    "timeout_seconds": 300,
    "max_retries": 3,
    "use_transactions": true
  },
  "chunking": {
    "chunk_size": 2000,
    "overlap_size": 200,
    "min_chunk_size": 1000
  },
  "chaptering": {
    "mode": "constrained",
    "target_length": 2500,
    "min_length": 1500,
    "max_length": 4000
  },
  "analysis": {
    "enable_scene_analysis": true,
    "enable_character_analysis": true,
    "enable_plot_analysis": true,
    "enable_style_analysis": true,
    "enable_coherence_check": true,
    "enable_enhancement": true,
    "enable_graph_analysis": true
  },
  "ai_providers": {
    "openai": {
      "model": "gpt-4o",
      "temperature": 0.7,
      "max_tokens": 4000
    },
    "gemini": {
      "model": "gemini-2.0-flash",
      "temperature": 0.6,
      "max_tokens": 3000
    },
    "deepseek": {
      "model": "deepseek-chat",
      "temperature": 0.5,
      "max_tokens": 2000
    }
  },
  "database": {
    "enable_age_graph": true,
    "batch_size": 50,
    "connection_timeout": 30
  },
  "testing": {
    "mock_ai_responses": false,
    "skip_slow_stages": false,
    "enable_debugging": true,
    "response_delay": 0.0,
    "enable_performance_metrics": true
  }
}