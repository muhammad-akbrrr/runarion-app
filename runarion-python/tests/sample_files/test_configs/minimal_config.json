{
  "description": "Minimal configuration for fast testing",
  "processing": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "timeout_seconds": 30,
    "max_retries": 2,
    "use_transactions": false
  },
  "chunking": {
    "chunk_size": 1000,
    "overlap_size": 100,
    "min_chunk_size": 500
  },
  "chaptering": {
    "mode": "flexible",
    "target_length": 1500,
    "min_length": 800,
    "max_length": 2500
  },
  "analysis": {
    "enable_scene_analysis": true,
    "enable_character_analysis": true,
    "enable_plot_analysis": false,
    "enable_style_analysis": false,
    "enable_coherence_check": true,
    "enable_enhancement": false
  },
  "testing": {
    "mock_ai_responses": true,
    "skip_slow_stages": true,
    "enable_debugging": false,
    "response_delay": 0.1
  }
}