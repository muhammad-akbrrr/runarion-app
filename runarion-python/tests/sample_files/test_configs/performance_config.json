{
  "description": "Performance-optimized configuration for fast testing",
  "processing": {
    "provider": "gemini",
    "model": "gemini-2.0-flash",
    "timeout_seconds": 60,
    "max_retries": 1,
    "use_transactions": false
  },
  "chunking": {
    "chunk_size": 1000,
    "overlap_size": 100,
    "min_chunk_size": 500
  },
  "chaptering": {
    "mode": "flexible",
    "target_length": 1500,
    "min_length": 1000,
    "max_length": 2500
  },
  "analysis": {
    "enable_scene_analysis": true,
    "enable_character_analysis": false,
    "enable_plot_analysis": true,
    "enable_style_analysis": false,
    "enable_coherence_check": false,
    "enable_enhancement": false,
    "enable_graph_analysis": false
  },
  "ai_providers": {
    "openai": {
      "model": "gpt-4o-mini",
      "temperature": 0.3,
      "max_tokens": 1500
    },
    "gemini": {
      "model": "gemini-2.0-flash",
      "temperature": 0.3,
      "max_tokens": 1500
    },
    "deepseek": {
      "model": "deepseek-chat",
      "temperature": 0.3,
      "max_tokens": 1500
    }
  },
  "database": {
    "enable_age_graph": false,
    "batch_size": 25,
    "connection_timeout": 15
  },
  "testing": {
    "mock_ai_responses": false,
    "skip_slow_stages": true,
    "enable_debugging": false,
    "response_delay": 0.0,
    "enable_performance_metrics": true
  }
}