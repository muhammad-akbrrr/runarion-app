# ============================================================================
# Staging deployment settings
# Usage:
#   cp .env.staging.example .env.staging
#   docker compose --env-file .env.staging -f docker-compose.staging.yml up -d --build
# ============================================================================

REGISTRY=localhost
TAG=staging

# Host-facing edge ports. Keep 80/443 on the VPS. For local rehearsal,
# use alternate values such as 8080/8443. `staging.sh` will derive the
# public HTTPS origin automatically from `STAGING_DOMAIN` plus
# `STAGING_HTTPS_PORT` for `APP_URL`, `VITE_REVERB_PORT`,
# `CORS_ALLOWED_ORIGINS`, and `REVERB_ALLOWED_ORIGINS`.
STAGING_HTTP_PORT=80
STAGING_HTTPS_PORT=443

STAGING_DOMAIN=staging.app.runarion.com
APP_URL=https://staging.app.runarion.com

APP_NAME=Runarion
APP_ENV=staging
APP_DEBUG=false
APP_KEY=base64:replace-with-real-app-key

DB_CONNECTION=pgsql
DB_HOST=postgres-db
DB_PORT=5432
DB_DATABASE=runarion
DB_USER=postgres
DB_PASSWORD=

# Pin this to an exact Apache AGE commit SHA before building staging.
AGE_REF=replace-with-apache-age-commit-sha
AGE_ENABLED=true
AGE_GRAPH_NAME=novel_pipeline_graph

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1

QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
CACHE_DRIVER=redis
FILESYSTEM_DISK=local

LOG_CHANNEL=stderr
LOG_LEVEL=info
PYTHON_LOG_LEVEL=INFO

SESSION_DOMAIN=staging.app.runarion.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

MAIL_MAILER=log
MAIL_FROM_ADDRESS=info@runarion.com
MAIL_FROM_NAME=Runarion Staging

PYTHON_SERVICE_URL=http://python-app:5000
CORS_ALLOWED_ORIGINS=https://staging.app.runarion.com

REVERB_APP_ID=replace-with-reverb-app-id
REVERB_APP_KEY=replace-with-reverb-app-key
REVERB_APP_SECRET=replace-with-reverb-app-secret
REVERB_ALLOWED_ORIGINS=https://staging.app.runarion.com
REVERB_HOSTNAME=staging.app.runarion.com
REVERB_SCALING_ENABLED=false
REVERB_SCHEME=https

VITE_APP_NAME=Runarion
VITE_REVERB_APP_KEY=replace-with-reverb-app-key
VITE_REVERB_CLIENT_HOST=staging.app.runarion.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
BCRYPT_ROUNDS=12

GOOGLE_DRIVE_CLIENT_ID=replace-me
GOOGLE_DRIVE_CLIENT_SECRET=replace-me
GOOGLE_DRIVE_REDIRECT_URI=https://staging.app.runarion.com/oauth/callback/google-drive

DROPBOX_CLIENT_ID=replace-me
DROPBOX_CLIENT_SECRET=replace-me
DROPBOX_REDIRECT_URI=https://staging.app.runarion.com/oauth/callback/dropbox

ONEDRIVE_CLIENT_ID=replace-me
ONEDRIVE_CLIENT_SECRET=replace-me
ONEDRIVE_REDIRECT_URI=https://staging.app.runarion.com/oauth/callback/onedrive

OPENAI_API_KEY=replace-me
OPENAI_MODEL_NAME=gpt-4o-mini
GEMINI_API_KEY=replace-me
GEMINI_MODEL_NAME=gemini-2.5-flash
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_MODEL_NAME=deepseek-chat

POSTGRES_MEMORY_LIMIT=1G
POSTGRES_MEMORY_RESERVATION=512M
LARAVEL_MEMORY_LIMIT=2048M
LARAVEL_MEMORY_RESERVATION=1024M
PYTHON_MEMORY_LIMIT=1024M
PYTHON_MEMORY_RESERVATION=512M
REDIS_MEMORY_LIMIT=256M
REDIS_MEMORY_RESERVATION=128M

LOG_DRIVER=json-file
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
